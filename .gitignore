# Claude Code — personal, machine-specific overrides (never commit)
.claude/settings.local.json

# OS junk
.DS_Store

# Node / Electron
node_modules/

# Build output
dist/
out/
build/*
# …but DO track the code-signing entitlements (a source file, not build output).
!build/entitlements.mac.plist

# Local config / secrets (never commit API keys)
.env
config.json

# Claude Code agent worktrees (transient)
.claude/worktrees/

# TypeScript: ALL runtime .js is compiled output of a sibling .ts source
# (in-place emit) — sources are the .ts files, never commit emitted .js.
/main.js
src/**/*.js
preload/**/*.js
renderer/**/*.js
scripts/**/*.js
*.tsbuildinfo
